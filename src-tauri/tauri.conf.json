{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "app-ly",
  "version": "0.26.3",
  "identifier": "com.mdn.app-ly",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../bundle/app.toml": "app.toml",
      "../example/contents/": "contents/",
      "../example/icon.png": "icon.png"
    }
  }
}
